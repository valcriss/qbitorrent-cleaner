QBITTORRENT_BASE_URL=http://127.0.0.1:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# Map container savePath prefixes to host filesystem prefixes.
# Format: /container/path:/host/path,/other/container:/other/host
PATH_MAPPINGS=/downloads:/srv/downloads

# Optional extra roots to scan. Useful when some torrents live outside the
# mapped save paths or when you want a broader audit surface.
SCAN_ROOTS=/srv/downloads

# Audit mode:
# - folder: compare torrent root entries against direct children on disk
# - file: compare exact files on disk using qBittorrent's torrent file list
AUDIT_MODE=folder

# Safety and filtering
DRY_RUN=true
EXCLUDE_TAGS=keep
EXCLUDE_CATEGORIES=
INCLUDE_CATEGORIES=
MIN_ORPHAN_AGE_DAYS=7
FOLLOW_SYMLINKS=false
IGNORE_NAMES=.DS_Store,Thumbs.db

# Output
OUTPUT_FILE=./orphan-report.json
REQUEST_TIMEOUT_MS=10000
VERBOSE=false
